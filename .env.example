# Connection to the Naimi service — only needed to PUBLISH templates and create
# per-client presentations. Building and previewing locally needs no account.
#
# 1. Sign up (free): https://app.naimi.ai/app/signup
# 2. Create an API token: https://app.naimi.ai/app/authoring
# 3. Copy this file to .env and fill in the values (or export them in your shell).
#    Your AI agent will pick them up from here. If you paste the onboarding
#    snippet from the app into your agent, it saves these here for you.

NAIMI_URL=https://app.naimi.ai
NAIMI_TOKEN=naimi_pk_...
